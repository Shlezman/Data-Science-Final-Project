# ─────────────────────────────────────────────────────────────────────────────
# MiroFish — LOCAL-ONLY .env (zero external egress)
# Copy to external/MiroFish/backend/.env on the box, fill the two <…> hosts, done.
# Every line here kills one egress vector the audit found (docs/miro/LOCAL_ONLY.md).
# MiroFish loads this with override=True, so these WIN over any shell env.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (ALL agent "thinking") ──────────────────────────────────────────────
# Default would be api.openai.com (or DashScope per the shipped .env.example).
# Point every LLM call at local Gemma-4 (Ollama 11434 / vLLM 8000). Key must be
# non-empty (constructor raises on empty) but its value is unused locally.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=local
LLM_MODEL_NAME=gemma-4
# Belt-and-suspenders for the OASIS subprocesses + camel-ai (read OPENAI_API_BASE_URL):
OPENAI_API_BASE_URL=http://localhost:11434/v1
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=local
# Parallel-run "boost" model — leave pointed local (blank would fall back to OpenAI):
LLM_BOOST_BASE_URL=http://localhost:11434/v1
LLM_BOOST_API_KEY=local
LLM_BOOST_MODEL_NAME=gemma-4

# ── Zep (knowledge-graph memory) ────────────────────────────────────────────
# Default would be Zep Cloud (api.getzep.com). Point at the self-hosted Zep from
# scripts/init_zep.sh. ⚠️ Whether the pinned zep-cloud==3.13.0 SDK honors this env
# var is version-dependent — RUN scripts/verify_local_egress.sh to confirm; if it
# does NOT, apply scripts/patch_mirofish_zep_local.py (forwards base_url in code).
# Set WITHOUT the /api/v2 suffix — the SDK appends it.
ZEP_API_URL=http://localhost:8000
ZEP_API_KEY=local

# ── HuggingFace (Twitter recsys model auto-download) ────────────────────────
# Only triggered if you enable the Twitter OASIS platform. Force offline + use a
# pre-populated cache so first run does not reach huggingface.co.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_HOME=/opt/hf-cache
