# SentiSense — Environment Variables
# ====================================
# Copy this file to .env and adjust values as needed.
# docker-compose and scripts read from .env automatically.

# ── PostgreSQL ──────────────────────────────────
POSTGRES_DB=sentisense
POSTGRES_USER=sentisense
POSTGRES_PASSWORD=sentisense_dev
POSTGRES_PORT=5432

# Full connection URL (used by Python scripts)
SENTISENSE_DATABASE_URL=postgresql://sentisense:sentisense_dev@localhost:5432/sentisense

# ── pgAdmin (optional, only with --profile admin) ──
PGADMIN_EMAIL=admin@sentisense.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── Ollama ──────────────────────────────────────
SENTISENSE_OLLAMA_MODEL=qwen2.5:14b
SENTISENSE_OLLAMA_BASE_URL=http://localhost:11434
SENTISENSE_OLLAMA_TEMPERATURE=0.1
SENTISENSE_OLLAMA_NUM_CTX=8192
SENTISENSE_OLLAMA_TIMEOUT=120
SENTISENSE_AGENT_RECURSION_LIMIT=10
SENTISENSE_AGENT_CONCURRENCY=7

# ── LLM Backend (ollama | openai) ─────────────
# Set to "openai" to use an OpenAI-compatible API instead of Ollama.
SENTISENSE_LLM_BACKEND=ollama

# ── OpenAI-compatible API (used when LLM_BACKEND=openai) ──
SENTISENSE_OPENAI_BASE_URL=https://10.10.248.21/v1
SENTISENSE_OPENAI_MODEL=mistral-large-2
SENTISENSE_OPENAI_TEMPERATURE=0.1
SENTISENSE_OPENAI_API_KEY=not-needed
SENTISENSE_OPENAI_TIMEOUT=120
SENTISENSE_OPENAI_MAX_RETRIES=2
SENTISENSE_OPENAI_VERIFY_SSL=false
SENTISENSE_OPENAI_HOST_HEADER=mistral-large-instruct-2407-gptq-runai-model-120b.cs.colman.ac.il

# ── Rate Limiting (requests per minute, 0 = unlimited) ──
SENTISENSE_RATE_LIMIT_RPM=0

# ── Manual Tool Calling ────────────────────────
# Force text-based ManualToolAgent for all models (required when the
# inference server does not support native tool/function calling,
# e.g. vLLM without --enable-auto-tool-choice).
SENTISENSE_FORCE_MANUAL_TOOLS=true
